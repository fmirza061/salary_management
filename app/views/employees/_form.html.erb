<div class="container mt-4">
  <%= form_with model: @employee do |f| %>

    <div class="mb-2">
      <%= f.label :full_name %>
      <%= f.text_field :full_name, class: "form-control" %>
    </div>

    <div class="mb-2">
      <%= f.label :job_title %>
      <%= f.text_field :job_title, class: "form-control" %>
    </div>

    <div class="mb-2">
      <%= f.label :country %>
      <%= f.text_field :country, class: "form-control" %>
    </div>

    <div class="mb-2">
      <%= f.label :salary %>
      <%= f.number_field :salary, class: "form-control" %>
    </div>

    <%= f.submit class: "btn btn-success" %>
  <% end %>
</div>