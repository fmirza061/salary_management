<div class="container mt-4">
  <h1>Employees</h1>

  <%= link_to "Add Employee", new_employee_path, class: "btn btn-primary mb-3" %>
  <%= link_to "Insights", insights_employees_path, class: "btn btn-secondary mb-3" %>

  <table class="table table-bordered">
    <thead>
      <tr>
        <th>Name</th>
        <th>Job</th>
        <th>Country</th>
        <th>Salary</th>
        <th>Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @employees.each do |e| %>
        <tr>
          <td><%= e.full_name %></td>
          <td><%= e.job_title %></td>
          <td><%= e.country %></td>
          <td><%= e.salary %></td>
          <td>
            <%= link_to "Edit", edit_employee_path(e), class: "btn btn-sm btn-warning" %>
            <%= link_to "Delete", employee_path(e), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-sm btn-danger" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%= paginate @employees %>
</div>